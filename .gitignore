__pycache__/
*.pyc

# --- SeqAn_MWE ---
# Compiled smoke-test binary (extensionless, not caught by the rules above).
SeqAn_MWE/smoke

# --- seqan_warmstart ---
# Compiled warm-start aligner binary (extensionless, built at the repo root by
# `make`). Leading slash anchors this to the root file so it does NOT match the
# src/seqan_warmstart/ source directory.
/seqan_warmstart
# Temp copy made by MSAMDD-Ling_MWE/balibase/optimum_compare.sh while swapping in
# the MUSCLE shim; removed on exit, ignored in case a run is interrupted.
/seqan_warmstart.real

# --- solver binaries ---
# Built at the repo root by `make`; large, platform-specific. Leading slash
# anchors to the root files (do not match any same-named source dirs).
/msa_aff
/msa_cnv

